# Local development defaults. Use the production example values on your host.
DJANGO_SECRET_KEY=replace-with-a-long-random-secret
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174
DJANGO_CSRF_TRUSTED_ORIGINS=
DATABASE_URL=
SECURE_SSL_REDIRECT=True

# Production example:
# DJANGO_SECRET_KEY=replace-with-a-real-long-random-secret
# DJANGO_DEBUG=False
# DJANGO_ALLOWED_HOSTS=your-backend-domain.com
# DJANGO_CORS_ALLOWED_ORIGINS=https://your-frontend-domain.com
# DJANGO_CSRF_TRUSTED_ORIGINS=https://your-frontend-domain.com
# DATABASE_URL=postgres://user:password@host:5432/database
# SECURE_SSL_REDIRECT=True
